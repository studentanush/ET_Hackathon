# Copy to .env and fill in. .env is gitignored.
GROQ_API_KEY=your_groq_key_here

# llama-3.3-70b-versatile: token-efficient, no reasoning-token overhead, good free-tier quota.
# Alternative (stronger reasoning, but ~10x tokens/call -> hits the 200k/day free limit fast): openai/gpt-oss-120b
SITEMIND_REASONING_MODEL=llama-3.3-70b-versatile
SITEMIND_FAST_MODEL=llama-3.1-8b-instant
SITEMIND_EMBED_MODEL=BAAI/bge-small-en-v1.5
